    "web:vercel:handoff": "tsx scripts/vercel_deployment_handoff.ts",
    "preview:web": "node scripts/serve-web.mjs dist 8082",
    "store:manifest": "node scripts/generate_store_manifest.mjs",
    "store:submission": "tsx scripts/store_submission_packet.ts",
    "store:screenshots": "python3 scripts/capture_store_screenshots.py",
    "store:check": "npm run store:manifest && npm run store:screenshots",
    "toolchain:ios": "bash scripts/bootstrap-ios-toolchain.sh",
    "native:android:debug": "bash scripts/android-debug-build.sh",
    "native:android:manifest": "node scripts/check_android_manifest.mjs",
    "native:qa:validate": "node scripts/validate_native_qa_evidence.mjs",
    "native:qa:runbook": "node scripts/native_qa_packet.mjs --stable-date",
