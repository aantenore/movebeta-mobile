{
  "name": "movebeta-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@tanstack/react-query": "^5.101.0",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "expo": "~56.0.12",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-media-library": "~56.0.7",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-video": "~56.1.4",
    "lucide-react-native": "^1.18.0",
    "movebeta-pose": "file:modules/movebeta-pose",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "quality": "npm run typecheck && npm test",
    "export:web": "expo export --platform web",
    "preview:web": "node scripts/serve-web.mjs dist 8082",
    "store:manifest": "node scripts/generate_store_manifest.mjs",
    "store:screenshots": "python3 scripts/capture_store_screenshots.py",
    "store:check": "npm run store:manifest && npm run store:screenshots",
    "toolchain:ios": "bash scripts/bootstrap-ios-toolchain.sh",
    "native:android:debug": "bash scripts/android-debug-build.sh",
    "native:android:manifest": "node scripts/check_android_manifest.mjs",
    "native:qa:validate": "node scripts/validate_native_qa_evidence.mjs",
    "native:qa:runbook": "node scripts/native_qa_packet.mjs --stable-date",
    "model:movenet:smoke": "node scripts/smoke_movenet_model.mjs",
    "model:movenet:readiness": "node scripts/movenet_readiness_report.mjs",
    "validation:cue": "node scripts/validate_cue_validation_dataset.mjs",
    "native:ios:pods": "bash scripts/ios-pods.sh",
    "handoff:git": "bash scripts/git-handoff-check.sh",
    "security:audit": "npm audit --audit-level=high",
    "release:eas:check": "node scripts/validate_eas_release.mjs",
    "release:eas:strict": "node scripts/validate_eas_release.mjs --strict",
    "release:readiness": "node scripts/launch_readiness_doctor.mjs",
    "release:full": "npm run release:check && npm run release:readiness",
    "release:check": "npm run quality && npm run model:movenet:readiness && npm run native:qa:runbook && npm run export:web && npm run release:eas:check && npm run security:audit",
    "ci": "npm run release:check"
  },
  "private": true
}
