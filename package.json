    "validation:cue:composition": "tsx scripts/cue_validation_dataset_composition_packet.ts",
    "validation:cue:doctor": "node scripts/cue_validation_dataset_doctor.mjs",
    "release:env:doctor": "node scripts/env_template_doctor.mjs",
    "release:credentials:starter": "tsx scripts/store_credentials_starter.ts",
    "release:credentials:doctor": "node scripts/store_credentials_doctor.mjs",
    "release:store-account:runbook": "tsx scripts/store_release_account_runbook.ts",
    "release:github:doctor": "node scripts/github_workflow_doctor.mjs",
    "release:blocker-issues": "tsx scripts/release_blocker_issue_report.ts",
    "release:blocker-progress": "tsx scripts/release_blocker_progress.ts",
    "release:blocker-issues:file": "tsx scripts/release_blocker_issue_filing.ts",
    "release:blocker-issues:links": "tsx scripts/release_blocker_issue_links.ts",
    "release:evidence:intake": "tsx scripts/external_evidence_intake.ts",
    "release:evidence:validate": "tsx scripts/external_evidence_validate.ts",
    "release:evidence:promote": "tsx scripts/external_evidence_promote.ts",
    "release:evidence:apply": "tsx scripts/external_evidence_apply.ts",
    "release:freshness:doctor": "tsx scripts/release_freshness_doctor.ts",
    "release:acquisition": "tsx scripts/acquisition_readiness_packet.ts",
    "release:data-room": "tsx scripts/data_room_index.ts",
    "feature:doctor": "node scripts/feature_completion_doctor.mjs",
    "model:movenet:assets:download": "node scripts/download_movenet_static_assets.mjs",
    "model:movenet:assets:check": "node scripts/movenet_static_assets_doctor.mjs",
    "model:assets:provenance": "node scripts/model_asset_provenance_doctor.mjs",
    "model:delivery:lifecycle": "tsx scripts/model_delivery_lifecycle_report.ts",
    "model:download:plan": "tsx scripts/model_download_plan_report.ts",
    "model:movenet:smoke": "node scripts/smoke_movenet_model.mjs",
    "model:movenet:readiness": "node scripts/movenet_readiness_report.mjs",
    "model:analysis:replay": "tsx scripts/model_analysis_replay.ts",
    "model:verification:suite": "tsx scripts/model_verification_suite.ts",
    "model:evidence:sync": "node scripts/sync_model_evidence.mjs",
    "validation:cue": "node scripts/validate_cue_validation_dataset.mjs",
    "native:ios:pods": "bash scripts/ios-pods.sh",
    "handoff:git": "bash scripts/git-handoff-check.sh",
    "security:audit": "npm audit --audit-level=moderate",
    "security:licenses": "node scripts/dependency_license_doctor.mjs",
    "release:license-review": "tsx scripts/license_review_packet.ts",
    "release:eas:check": "node scripts/validate_eas_release.mjs",
    "release:eas:strict": "node scripts/validate_eas_release.mjs --strict",
    "release:readiness": "node scripts/launch_readiness_doctor.mjs",
    "release:archives": "node scripts/release_archives.mjs",
    "release:handoff": "node scripts/release_handoff_packet.mjs",
    "release:full": "npm run release:check && npm run release:readiness && npm run release:freshness:doctor && npm run release:archives && npm run release:handoff",
    "release:check": "node scripts/release_check.mjs",
    "ci": "npm run release:check"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "private": true
