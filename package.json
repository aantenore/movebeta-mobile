  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "quality": "npm run typecheck && npm test",
    "export:web": "expo export --platform web && node scripts/prepare_pwa_dist.mjs",
    "web:pwa:check": "node scripts/pwa_readiness_doctor.mjs",
    "web:smoke:report": "node scripts/web_smoke_report.mjs",
